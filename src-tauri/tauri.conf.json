{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Liberty",
  "version": "0.1.0",
  "identifier": "com.westng.liberty",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Liberty",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
